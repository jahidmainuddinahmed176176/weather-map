generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Favorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  city      String
  lat       Float
  lon       Float
  createdAt DateTime @default(now())
}